# Arkiv portal — users + devices on Braga (frontend uses @arkiv-network/sdk directly)
PORTAL_WALLET_PRIVATE_KEY=
# Optional: skip deriving address from private key
# PORTAL_WALLET_ADDRESS=
# Optional: portal entity project namespace (default openclu-portal-v1)
# ARKIV_PORTAL_PROJECT_VALUE=openclu-portal-v1

# Privy auth (browser)
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_APP_CLIENT_ID=

# Local dev: point at orchestrator on this PC (fixes 404 from old ngrok cookie)
ORCHESTRATOR_URL=http://127.0.0.1:8790

# Skill + training catalog project namespace (default skill-capture-ai-catalog-v1)
# ARKIV_PROJECT_VALUE=skill-capture-ai-catalog-v1
