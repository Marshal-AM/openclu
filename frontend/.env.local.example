# Supabase — portal + catalog (required for dashboard marketplace and device registration)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Portal wallet — optional legacy; portal rows are written via Supabase service role
PORTAL_WALLET_PRIVATE_KEY=

# Privy auth (browser)
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_APP_CLIENT_ID=

# Local dev: point at orchestrator on this PC (fixes 404 from old ngrok cookie)
ORCHESTRATOR_URL=http://127.0.0.1:8790

# Device: skill-capture/.env has GROQ_API_KEY, NGROK_AUTHTOKEN, FRONTEND_URL (for register.sh → this app)
# Pi distribute also needs SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY in skill-capture/.env
