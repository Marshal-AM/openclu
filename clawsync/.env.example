# Local vision trainer (Train your AI tab)
# VITE_LOCAL_TRAINER_URL=http://127.0.0.1:8000

# Convex
CONVEX_DEPLOYMENT=

# Required - Default model provider
ANTHROPIC_API_KEY=

# Multi-model support (optional)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENCODE_ZEN_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=

# Agent wallet — Story Aeneid purchases + future on-chain agent actions (local Convex dev only)
# Buyer wallet for skill purchases (Story Aeneid). Used by local Convex actions and the marketplace CLI.
# Copy to .env for local dev. Convex does not read .env by default — also run:
#   npx convex env set AGENT_PRIVATE_KEY <same-hex>
# (Local dev also loads keys from clawsync/.env when Convex env is empty.)
AGENT_PRIVATE_KEY=0x7a425200e31e8409c27abbc9aaae49a94c314426ef2e569d3a33ffc289a34e76

# Chat models — must also be in Convex env for chat actions:
#   npx convex env set GROQ_API_KEY gsk_...
GROQ_API_KEY=

# Optional Helia block cache inside clawsync (speeds repeat downloads on same machine)
# HELIA_DATA_DIR=C:\path\to\clawsync\data\.helia-data

# For skill purchases: run `npm run cdr-storage` in a second terminal (keeps Helia warm).
# Purchase auto-uses http://127.0.0.1:8787 when healthy; avoids slow libp2p boot inside Convex.
# CDR_STORAGE_URL=http://127.0.0.1:8787

# Public IPFS pin at publish/repin (required for buyers on any device).
PINATA_API_KEY=
PINATA_SECRET_KEY=
# PINATA_JWT=

# Buyer fetch — stored in Arkiv ops.ipfsGatewayUrl at publish.
PINATA_BUYER_GATEWAY=https://gateway.pinata.cloud/ipfs
# IPFS_GATEWAY=https://ipfs.io/ipfs


# Decrypted skill bundles from marketplace purchases (default: data/purchased-skills)
PURCHASED_SKILLS_DIR=



# Channels - Phase 4 (set as needed)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
RESEND_API_KEY=

# Voice - Phase 5 (optional)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Cloudflare R2 storage (optional, Convex native storage is default)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Stagehand / Browserbase (optional, for browser automation)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Firecrawl (optional, for web scraping)
FIRECRAWL_API_KEY=

# X / Twitter API (for research search, optional)
X_BEARER_TOKEN=

# Supermemory (optional, for persistent agent memory)
SUPERMEMORY_API_KEY=
