# Supabase — required for catalog publish from device (copy from frontend/.env)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Copy this file to .env in the same folder (never commit .env).
GROQ_API_KEY=
CDR_PUBLISH=1

# Pin ciphertext to public IPFS at distribute/publish (required for marketplace buyers).
# Preferred (DeepShare): API key + secret from https://app.pinata.cloud/developers/api-keys
PINATA_API_KEY=
PINATA_SECRET_KEY=
# Optional fallback: scoped JWT (v3 upload)
# PINATA_JWT=

# Buyer HTTP gateway (stored in catalog ops.ipfsGatewayUrl). Use public gateway for API-key pins.
PINATA_BUYER_GATEWAY=https://gateway.pinata.cloud/ipfs
# Optional dedicated subdomain (may require gateway access token for reads)
# PINATA_GATEWAY=your-subdomain.mypinata.cloud

# Device wallet (set by register.sh — do not commit real keys)
DEVICE_ID=
DEVICE_NAME=
DEVICE_SALT=
DEVICE_WALLET_ADDRESS=
DEVICE_WALLET_PRIVATE_KEY=
REGISTRATION_TOKEN=
FRONTEND_URL=http://localhost:3000

# ngrok — orchestrator starts tunnel on npm run start; URL printed in logs + ORCHESTRATOR_PUBLIC_URL
NGROK_AUTHTOKEN=
# NGROK_DISABLED=1
ORCHESTRATOR_PORT=8790
ORCHESTRATOR_PUBLIC_URL=
