# Creator wallet — funds allocate/write txs and IP registration (no 0x prefix)
WALLET_PRIVATE_KEY=

# Buyer wallet for purchase-skill.ts (defaults to WALLET_PRIVATE_KEY if unset)
BUYER_PRIVATE_KEY=

# Story Aeneid
RPC_URL=https://aeneid.storyrpc.io
API_URL=http://172.192.41.96:1317

# License mint fee paid in WIP (wrapped IP). Default 1 IP.
LICENSE_MINT_FEE_IP=1

# Set to 0 in skill-capture/.env to skip CDR after recording
# CDR_PUBLISH=1

# Decrypt/purchase timeouts (ms). Default 300000 (5 min) for validator collection.
# CDR_DECRYPT_TIMEOUT_MS=300000
# CDR_POLL_LOG_INTERVAL_MS=5000

# Skip wrap/approve/mint if you already own a license (set LICENSE_TOKEN_ID)
# SKIP_LICENSE_MINT=0
# LICENSE_TOKEN_ID=

# Helia cat() timeout after dialing publisher peers (ms)
# IPFS_DOWNLOAD_TIMEOUT_MS=120000

# E2E: skip Story/CDR re-encrypt; still runs index-arkiv to refresh Arkiv ops
# E2E_SKIP_PUBLISH=1
